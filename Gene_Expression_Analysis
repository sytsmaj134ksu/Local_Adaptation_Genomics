#!/usr/bin/env bash
set -euo pipefail
source "$(dirname "$0")/../config.sh"

tail -n +2 "${METADATA}" | while IFS=, read -r sample_id fastq_r1 fastq_r2 site ecotype treatment replicate; do
  r1="${TRIMMED_FASTQ_DIR}/${sample_id}_R1.fastp.fastq.gz"
  r2="${TRIMMED_FASTQ_DIR}/${sample_id}_R2.fastp.fastq.gz"
  sam="${SAM_DIR}/${sample_id}.sam"

  hisat2 \
    -x "${HISAT2_INDEX_PREFIX}" \
    --threads "${THREADS}" \
    -1 "${r1}" \
    -2 "${r2}" \
    -S "${sam}" \
    > "${LOG_DIR}/${sample_id}.hisat2.log" 2>&1

done

#!/usr/bin/env bash
set -euo pipefail
source "$(dirname "$0")/../config.sh"

for sam in "${SAM_DIR}"/*.sam; do
  sample_id="$(basename "${sam}" .sam)"
  bam="${BAM_DIR}/${sample_id}.sorted.bam"

  samtools view -@ "${THREADS}" -u "${sam}" | \
    samtools sort -@ "${THREADS}" -o "${bam}"

  samtools index "${bam}"
  samtools flagstat "${bam}" > "${FLAGSTAT_DIR}/${sample_id}.flagstat.txt"
done
