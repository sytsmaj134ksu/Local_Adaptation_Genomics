#!/usr/bin/env bash
set -euo pipefail
source "$(dirname "$0")/../config.sh"

# Trim paired-end FASTQ files listed in metadata.
tail -n +2 "${METADATA}" | while IFS=, read -r sample_id fastq_r1 fastq_r2 site ecotype treatment replicate; do
  r1="${RAW_FASTQ_DIR}/${fastq_r1}"
  r2="${RAW_FASTQ_DIR}/${fastq_r2}"
  out_r1="${TRIMMED_FASTQ_DIR}/${sample_id}_R1.fastp.fastq.gz"
  out_r2="${TRIMMED_FASTQ_DIR}/${sample_id}_R2.fastp.fastq.gz"

  if [[ ! -f "${r1}" || ! -f "${r2}" ]]; then
    echo "Missing FASTQ files for ${sample_id}: ${r1} ${r2}" >&2
    exit 1
  fi

  fastp \
    --thread "${THREADS}" \
    --in1 "${r1}" \
    --in2 "${r2}" \
    --out1 "${out_r1}" \
    --out2 "${out_r2}" \
    --qualified_quality_phred 20 \
    --length_required 36 \
    --html "${FASTP_OUT_DIR}/${sample_id}.fastp.html" \
    --json "${FASTP_OUT_DIR}/${sample_id}.fastp.json" \
    > "${LOG_DIR}/${sample_id}.fastp.log" 2>&1

done

fastqc --threads "${THREADS}" --outdir "${FASTP_OUT_DIR}" "${TRIMMED_FASTQ_DIR}"/*.fastq.gz

